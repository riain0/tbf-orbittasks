{
  "name": "orbittasks",
  "version": "0.1.0",
  "private": true,
  "description": "OrbitTasks SaaS — Build Fellowship sample project.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "install:all": "npm install --workspaces --include-workspace-root",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspace=apps/api && npm run test --workspace=apps/web",
    "build": "npm run build --workspace=apps/api && npm run build --workspace=apps/web",
    "deploy": "bash scripts/deploy.sh",
    "ci": "bash scripts/measure.sh",
    "analyze-baseline": "node scripts/analyze-baseline.js",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "tsx": "^4.7.1",
    "typescript": "^5.4.5"
  }
}
