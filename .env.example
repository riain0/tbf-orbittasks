# Copy this file to .env and fill in values.
PORT=3001
NODE_ENV=development

# Required. Any random string for local dev; used to sign auth tokens.
JWT_SECRET=replace-me-with-a-random-string-for-local-dev

# Required. File-backed JSON store (a plain JSON file on disk, no SQLite).
# Under tests this is in-memory only.
DATABASE_URL=file:.data/orbittasks.json
